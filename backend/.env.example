# Database (without Docker: create role first - see backend/scripts/setup_db.sql)
# Run: sudo -u postgres psql -f backend/scripts/setup_db.sql
# Or use your existing postgres user: postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/paritycheck
DATABASE_URL=postgresql+asyncpg://paritycheck:paritycheck@localhost:5432/paritycheck

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Frontend URL (for verification links, OAuth redirect)
FRONTEND_URL=http://localhost:5173

# Backend URL (for GitHub OAuth callback - must match your backend's public URL)
BACKEND_URL=http://localhost:8000

# GitHub OAuth (create app at https://github.com/settings/developers)
# Callback URL in GitHub app: {BACKEND_URL}/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (SMTP) - for verification emails
# Gmail: Enable 2FA, create App Password at https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@paritycheck.io

# Set to false to actually send emails (true = log links only, for dev)
DEV_SKIP_EMAIL=true
