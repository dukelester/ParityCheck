# Database
DATABASE_URL=postgresql+asyncpg://paritycheck:paritycheck@localhost:5432/paritycheck

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Frontend URL (for verification links)
FRONTEND_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@paritycheck.io

# Dev: set to true to log verification links instead of sending email
DEV_SKIP_EMAIL=true
